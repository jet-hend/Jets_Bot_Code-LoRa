{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Project",
      "type": "shell",
      "command": "./build.sh",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Clean Build",
      "type": "shell",
      "command": "./clean.sh",
      "group": "build"
    },
    {
      "label": "Run Bot",
      "type": "shell",
      "command": "./run.sh",
      "group": "test",
      "problemMatcher": []
    }
  ]
}